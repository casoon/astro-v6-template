---
import { ArticleSchema, Schema } from '@casoon/astro-structured-data/components';

export interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  robots?: string;
  /** @deprecated Use robots prop instead */
  noIndex?: boolean;
  articleAuthor?: string;
  articleDate?: Date;
  articleModified?: Date;
}

const {
  title,
  description,
  canonicalUrl,
  ogImage,
  ogType = 'website',
  robots,
  noIndex = false,
  articleAuthor,
  articleDate,
  articleModified,
} = Astro.props;

const resolvedCanonical = canonicalUrl || Astro.url.href;

const useArticleSchema = ogType === 'article' && !!articleDate && !!ogImage;
---

{robots ? <meta name="robots" content={robots} /> : noIndex && <meta name="robots" content="noindex, nofollow" />}

{useArticleSchema ? (
  <ArticleSchema
    title={title}
    description={description}
    datePublished={articleDate!.toISOString()}
    dateModified={articleModified?.toISOString()}
    authorName={articleAuthor ?? 'Unknown'}
    imageUrl={ogImage!}
  />
) : (
  <Schema item={{ '@type': 'WebPage', name: title, description, url: resolvedCanonical, ...(ogImage && { image: ogImage }) }} />
)}
