---
export interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  twitterCard?: 'summary' | 'summary_large_image';
  /** Robots meta content, e.g. "noindex, follow" or "noindex, nofollow" */
  robots?: string;
  /** @deprecated Use robots prop instead */
  noIndex?: boolean;
  articleAuthor?: string;
  articleDate?: Date;
}

const {
  title,
  description,
  canonicalUrl,
  ogImage,
  ogType = 'website',
  twitterCard = 'summary_large_image',
  robots,
  noIndex = false,
  articleAuthor,
  articleDate,
} = Astro.props;

const resolvedCanonical = canonicalUrl || Astro.url.href;

const jsonLd =
  ogType === 'article'
    ? {
        '@context': 'https://schema.org',
        '@type': 'Article',
        headline: title,
        description,
        url: resolvedCanonical,
        ...(ogImage && { image: ogImage }),
        ...(articleAuthor && { author: { '@type': 'Person', name: articleAuthor } }),
        ...(articleDate && { datePublished: articleDate.toISOString() }),
      }
    : {
        '@context': 'https://schema.org',
        '@type': 'WebPage',
        name: title,
        description,
        url: resolvedCanonical,
      };
---

{robots ? <meta name="robots" content={robots} /> : noIndex && <meta name="robots" content="noindex, nofollow" />}
<link rel="canonical" href={resolvedCanonical} />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={ogType} />
<meta property="og:url" content={resolvedCanonical} />
{ogImage && <meta property="og:image" content={ogImage} />}

<!-- Twitter -->
<meta name="twitter:card" content={twitterCard} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{ogImage && <meta name="twitter:image" content={ogImage} />}

<!-- JSON-LD -->
<script
  type="application/ld+json"
  set:html={JSON.stringify(jsonLd)}
/>
