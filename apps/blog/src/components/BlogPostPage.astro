---
import Navbar from '@astro-v6/shared/components/Navbar.astro';
import Tag from '@astro-v6/shared/components/Tag.astro';
import ThemeToggle from '@astro-v6/shared/components/ThemeToggle.svelte';
import BaseLayout from '@astro-v6/shared/layouts/BaseLayout.astro';
import PageSEO from '@astro-v6/shared/seo/PageSEO.astro';
import type { Locale } from '@astro-v6/shared/utils/i18n';
import { localePath, switchLocalePath } from '@astro-v6/shared/utils/i18n';
import { t } from '@/i18n';
import type { BlogPost } from '@/utils/blog-posts';
import { render } from 'astro:content';

interface Props {
  locale: Locale;
  post: BlogPost;
}

const { locale, post } = Astro.props;
const tr = t(locale);
const isGerman = locale === 'de';
const { Content } = await render(post);

const title = isGerman ? (post.data.titleDe ?? post.data.title) : post.data.title;
const description = isGerman
  ? (post.data.descriptionDe ?? post.data.description)
  : post.data.description;
const alternateHref = switchLocalePath(Astro.url.pathname, isGerman ? 'en' : 'de');
const alternateLabel = isGerman ? 'EN' : 'DE';
const dateLocale = isGerman ? 'de-DE' : 'en-US';
const links = [{ href: localePath('/', locale), label: tr('nav.home') }];
---

<BaseLayout title={title} description={description} lang={locale}>
  <PageSEO
    slot="head"
    title={`${title} - Astro v6 Blog`}
    description={description}
    ogType="article"
    ogImage={new URL(`/og/blog/${post.id}.png`, Astro.site).href}
    articleAuthor={post.data.author}
    articleDate={post.data.date}
  />

  <Navbar slot="header" siteName="Astro v6 Blog" links={links}>
    <a href={alternateHref} class="text-xs font-medium text-text-secondary hover:text-text no-underline">{alternateLabel}</a>
    <ThemeToggle client:load />
  </Navbar>

  <article class="mx-auto max-w-3xl px-6 py-12">
    <header class="mb-12">
      <time datetime={post.data.date.toISOString()} class="mb-2 block text-sm text-text-secondary">
        {post.data.date.toLocaleDateString(dateLocale, { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      <h1 class="mb-2 text-[clamp(1.75rem,4vw,2.5rem)] font-extrabold leading-snug tracking-tight">{title}</h1>
      <p class="text-[0.9375rem] text-text-secondary">{tr('post.by')} {post.data.author}</p>
      {
        post.data.tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-1">
            {post.data.tags.map((tag: string) => (
              <Tag>{tag}</Tag>
            ))}
          </div>
        )
      }
    </header>

    <div class="post-content">
      <Content />
    </div>

    <footer class="mt-12 border-t border-border pt-8">
      <a href={localePath('/', locale)} class="font-semibold">&larr; {tr('post.back')}</a>
    </footer>
  </article>

  <footer slot="footer" class="border-t border-border px-6 py-8 text-center text-sm text-text-secondary">
    <p>&copy; {new Date().getFullYear()} Astro v6 Blog.</p>
  </footer>
</BaseLayout>

<style>
  /* MDX content requires :global() scoped styles. */
  .post-content {
    line-height: 1.8;
  }

  .post-content :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
  }

  .post-content :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
  }

  .post-content :global(p) {
    margin-bottom: var(--space-md);
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    padding-left: var(--space-lg);
    margin-bottom: var(--space-md);
  }

  .post-content :global(li) {
    margin-bottom: var(--space-xs);
  }

  .post-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    padding: 0.125em 0.375em;
    background: var(--color-bg-secondary);
    border-radius: var(--radius-sm);
  }

  .post-content :global(pre) {
    padding: var(--space-lg);
    border-radius: var(--radius-lg);
    background: var(--color-neutral-900) !important;
    overflow-x: auto;
    margin-bottom: var(--space-md);
  }

  .post-content :global(pre code) {
    padding: 0;
    background: transparent;
  }

  .post-content :global(strong) {
    font-weight: 700;
  }
</style>
